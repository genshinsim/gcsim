options swap_delay=12 iteration=1000;

active mavuika;

target lvl=100 resist=0.1 radius=2 pos=0,2.4 hp=999999999;
energy every interval=480,720 amount=1;

fn mualani_combo2() {
  #doing 2[3-stacked bite]
  while .mualani.nightsoul.state {
    for let k=0; k<2; k=k+1 {
      while .mualani.momentum < 3 {
        mualani walk[f=1];
      }
      mualani attack;
    }
    break;
  }
}

fn mualani_combo3() {
  #doing 3[3-stacked bite]
  while .mualani.nightsoul.state {
    for let k=0; k<3; k=k+1 {
      while .mualani.momentum < 3 {
        mualani walk[f=1];
      }
      mualani attack;
    }
    break;
  }
}

for let i=0; i<6; i=i+1 {

  mona skill;

  if .mav.burst.ready {
    mav burst, skill, attack;
  } else {
    mav charge, skill[hold=1];
  }
  mona burst, attack;
  sucrose skill, dash;
  if .sucrose.burst.ready {
    sucrose burst;
  }
  mualani skill;
  if .mualani.burst.ready {
    mualani walk, burst;
    mualani_combo2();
  }
  else {
    mualani_combo3();
  }


}
