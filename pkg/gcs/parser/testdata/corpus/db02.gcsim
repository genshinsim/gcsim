let _execute_action = execute_action;
fn execute_action(char_id number, action_id number, p map) {
  if action_id == .action.dash {
	pick_up_crystallize("any"); # Pick up crystallize before every dash
  }
	
  return _execute_action(char_id, action_id, p);
}

options swap_delay=12 iteration=1000;

navia char lvl=90/90 cons=0 talent=9,9,9;
navia add weapon="serpentspine" refine=1 lvl=90/90 +params=[stacks=5];
navia add set="nighttime" count=4;
navia add stats hp=4780 atk=311 atk%=0.466 geo%=0.466 cd=0.622;
navia add stats def%=0.124 def=39.36 hp=507.88 hp%=0.0992 atk=33.08 atk%=0.1984 er=0.1102 em=39.64 cr=0.3972 cd=0.662;

zhongli char lvl=90/90 cons=0 talent=9,9,9;
zhongli add weapon="favoniuslance" refine=3 lvl=90/90;
zhongli add set="totm" count=4;
zhongli add stats hp=4780 atk=311 hp%=0.466 geo%=0.466 cr=0.311;
zhongli add stats def%=0.124 def=39.36 hp=507.88 hp%=0.1984 atk=33.08 atk%=0.0992 er=0.1102 em=39.64 cr=0.3310 cd=0.7944;

ganyu char lvl=90/90 cons=0 talent=9,9,9;
ganyu add weapon="favoniuswarbow" refine=3 lvl=90/90;
ganyu add set="eosf" count=4;
ganyu add stats hp=4780 atk=311 atk%=0.466 cryo%=0.466 cr=0.311 ; #main
ganyu add stats def=39.36 def%=0.124 hp=507.88 hp%=0.0992 atk=33.08 atk%=0.1984 er=0.1102 em=39.64 cr=0.331 cd=0.7944;	

rosaria char lvl=90/90 cons=6 talent=9,9,9; 
rosaria add weapon="favlance" refine=3 lvl=90/90;
rosaria add set="no" count=5;
rosaria add stats hp=4780 atk=311 atk%=0.466 cryo%=0.466 cr=0.311 ; #main
rosaria add stats def=39.36 def%=0.124 hp=507.88 hp%=0.0992 atk=33.08 atk%=0.1984 er=0.1102 em=39.64 cr=0.331 cd=0.7944;

target lvl=100 resist=0.1 radius=2 pos=0,2.4 hp=999999999;
energy every interval=480,720 amount=1;

active zhongli;
for let x=0; x<4; x=x+1 {
  zhongli skill[hold=1], dash;
  while !.zhongli.mods.favonius-cd { 
    zhongli attack; 
  }
  navia burst;
  rosaria skill, burst; pick_up_crystallize("any");
  ganyu burst, skill;
  while !.ganyu.mods.favonius-cd { 
    ganyu attack;                                    print(.navia.shrapnel);
  }
  navia skill[hold=1], attack:3, dash, attack:2;     print(.navia.shrapnel);
  rosaria skill;        pick_up_crystallize("any");  print(.navia.shrapnel);
  rosaria dash;                                      print(.navia.shrapnel);
  navia skill, attack:2, dash;
}
