# ----  Default Enemy
options swap_delay=12 debug=true iteration=1000;
target lvl=100 resist=0.1 hp=100000000 pos=0,1.5 radius=1;
target lvl=100 resist=0.1 hp=100000000 pos=-1.2,3.5 radius=1;
#target lvl=100 resist=0.1 hp=100000000 pos=1.2,3.5 radius=1;
#target lvl=100 resist=0.1 hp=100000000 pos=0,5.5 radius=1;
energy every interval=480,720 amount=1;

active neuv;
for let i = 0; i < 3; i = i + 1 {
  neuv burst;
  venti attack, skill, burst;
  shenhe burst, skill[hold=1];
  ganyu skill, burst;
  neuv charge, charge, skill, attack:3;
  venti attack:2, skill, attack;
  shenhe attack:2, dash, skill[hold=1];
  ganyu skill, burst;
  neuv charge, skill, charge;
}
wait(173);

