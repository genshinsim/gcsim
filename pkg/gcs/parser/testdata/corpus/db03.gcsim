options swap_delay=12 iteration=1000;
energy every interval=480,720 amount=1;
target lvl=100 resist=0.1 radius=2 pos=0,2.4 hp=999999999; 

active furina;
for let i=0; i<4; i=i+1 {
 furina skill, attack, burst;
 while !.furina.mods.favonius-cd {
 furina attack;}
 
 ganyu skill, burst;
 while !.ganyu.mods.favonius-cd {
 ganyu attack;}
 
 jean skill, burst;
 
  wrio  skill,
        attack:5, charge, dash,
        attack:5, charge, dash,
        attack:5, charge, dash;  
  if .wrio.burst.ready && .wrio.energy == .wrio.energymax  {
    wrio burst;
  }
  jean skill, attack:2;
}

